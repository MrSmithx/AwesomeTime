{
    "layout": {
        "type": "layout",
        "pages": [
          "timePage",
          "datePage",
          "weatherPage",
          "otherPage"
        ],

        "timePage": {
          "type": "page",
          "title": "Time Settings",
          "sections": [
            "timeSection",
            "fuzzySection",
            "transitionSection"
          ]
        },

        "datePage": {
          "type": "page",
          "title": "Date Settings",
          "sections": [
            "dateSection"
          ]
        },

        "weatherPage": {
          "type": "page",
          "title": "Weather Settings",
          "sections": [
            "weatherLocationSection",
            "weatherSection"
          ]
        },

        "otherPage": {
          "type": "page",
          "title": "Appearance",
          "sections": [
            "shadowSection",
            "otherSection"
          ]
        },

        "timeSection": {
          "type": "section",
          "title": "Display",
          "keys": [
            "show-time",
            "time-prefix",
            "text-case",
            "font-family",
            "font-color"
          ]
        },

        "fuzzySection": {
          "type": "section",
          "title": "Fuzzy Settings",
          "keys": [
            "fuzzy-time",
            "fuzzy-level"
          ]
        },

        "transitionSection": {
            "type": "section",
            "title": "Transition Settings",
            "keys": [
                "time-transition",
                "transition-duration",
                "transition-distance"
            ]
        },

        "dateSection": {
          "type": "section",
          "title": "Display",
          "keys": [
            "show-date",
            "date-format",
            "date-prefix",
            "date-case",
            "date-align",
            "date-position",
            "date-font-family",
            "date-color",
            "use-noon-midnight"
          ]
        },

        "weatherSection": {
          "type": "section",
          "title": "Display",
          "keys": [
            "weather-font-family",
            "weather-color",
            "weather-case",
            "weather-align",
            "weather-units",
            "weather-show-condition",
            "weather-show-icon",
            "weather-show-sun",
            "weather-sun-font-family",
            "weather-sun-color"
          ]
        },

        "weatherLocationSection": {
          "type": "section",
          "title": "Weather Location Settings",
          "keys": [
            "show-weather",
            "weather-location-mode",
            "weather-city",
            "weather-country",
            "weather-location-display"
          ]
        },

        "shadowSection": {
          "type": "section",
          "title": "Text Shadow ",
          "keys": [
            "text-shadow-enabled",
            "text-shadow-color",
            "text-shadow-offset",
            "text-shadow-blur"
          ]
        },

        "otherSection": {
          "type": "section",
          "title": "General Appearance",
          "keys": [
            "line-spacing",
            "font-opacity",
            "label-background-color",
            "label-background-opacity"
          ]
        }
    },

    "show-time": {
        "type": "switch",
        "default": true,
        "description": "Show Time"
    },

    "font-family": {
        "type": "fontchooser",
        "default": "Sans 14",
        "description": "Time Font"
    },

    "font-color": {
        "type": "colorchooser",
        "default": "#FFFFFF",
        "description": "Time Color"
    },

    "time-prefix": {
        "type": "entry",
        "default": "",
        "description": "Time Prefix"
    },

    "text-case": {
        "type": "combobox",
        "default": "normal",
        "description": "Time Text Case",
        "options": {
            "Normal": "normal",
            "UPPERCASE": "upper",
            "lowercase": "lower",
            "Capitalise Words": "title"
        }
    },

    "time-transition": {
        "type": "combobox",
        "default": "fade",
        "description": "Time Transition",
        "options": {
            "None": "none",
            "Fade": "fade",
            "Slide": "slide",
            "Crossfade": "crossfade",
            "Flip X": "flipX",
            "Flip Y": "flipY",
            "Zoom": "zoom"
        }
    },

    "transition-duration": {
        "type": "spinbutton",
        "default": 300,
        "min": 50,
        "max": 2000,
        "step": 50,
        "units": "",
        "description": "Transition Duration [ ms ]",
        "dependency": "time-transition!=none"
    },

    "transition-distance": {
        "type": "spinbutton",
        "default": 20,
        "min": 5,
        "max": 100,
        "step": 1,
        "units": "",
        "description": "Slide Distance [ px ]",
        "dependency": "time-transition!=none"
    },

    "show-date": {
        "type": "switch",
        "default": true,
        "description": "Show Date"
    },

    "date-font-family": {
        "type": "fontchooser",
        "default": "Sans 14",
        "description": "Date Font"
    },

    "date-format": {
        "type": "entry",
        "default": "%A %d %B %Y",
        "description": "Date Format"
    },

    "date-color": {
        "type": "colorchooser",
        "default": "#cccccc",
        "description": "Date Color"
    },

    "date-prefix": {
        "type": "entry",
        "default": "",
        "description": "Date Prefix"
    },

    "date-case": {
        "type": "combobox",
        "default": "normal",
        "description": "Date Text Case",
        "options": {
            "Normal": "normal",
            "UPPERCASE": "upper",
            "lowercase": "lower",
            "Capitalise Words": "title"
        }
    },

    "use-noon-midnight": {
        "type": "switch",
        "default": true,
        "description": "Use Noon / Midnight"
    },

    "date-align": {
        "type": "combobox",
        "default": "left",
        "description": "Date Alignment",
        "options": {
            "Left": "left",
            "Centre": "center",
            "Right": "right"
        }
    },

    "date-position": {
        "type": "combobox",
        "default": "below",
        "description": "Date Position",
        "options": {
            "Above Time": "above",
            "Below Time": "below"
        }
    },

    "fuzzy-time": {
        "type": "switch",
        "default": false,
        "description": "Fuzzy Time Mode",
    },

    "fuzzy-level": {
        "type": "combobox",
        "default": "medium",
        "description": "Fuzziness Level",
        "dependency": "fuzzy-time",
        "options": {
            "Subtle": "low",
            "Normal": "medium",
            "Very Fuzzy": "high"
        }
    },

    "show-weather": {
        "type": "switch",
        "default": true,
        "description": "Show Weather"
    },

    "weather-location-mode": {
        "type": "combobox",
        "default": "auto",
        "description": "Location Source [ IP Location ]",
        "options": {
            "Automatic": "auto",
            "Manual": "manual"
        }
    },

    "weather-city": {
        "type": "entry",
        "default": "Sydney",
        "description": "City",
        "dependency": "weather-location-mode=manual"
    },

    "weather-country": {
        "type": "entry",
        "default": "Australia",
        "description": "Country",
        "dependency": "weather-location-mode=manual"
    },

    "weather-location-display": {
        "type": "combobox",
        "default": "city-country",
        "description": "Location Display",
        "options": {
            "None": "none",
            "City": "city",
            "Country": "country",
            "City, Country": "city-country"
        }
    },

    "weather-font-family": {
        "type": "fontchooser",
        "default": "Sans 14",
        "description": "Weather Font"
    },

    "weather-color": {
        "type": "colorchooser",
        "default": "#FFFFFF",
        "description": "Weather Color"
    },

    "weather-case": {
        "type": "combobox",
        "default": "normal",
        "description": "Weather Text Case",
        "options": {
            "Normal": "normal",
            "UPPERCASE": "upper",
            "lowercase": "lower",
            "Capitalise Words": "title"
        }
    },

    "weather-units": {
        "type": "combobox",
        "default": "celsius",
        "description": "Temperature Units",
        "options": {
            "Celsius (°C)": "celsius",
            "Fahrenheit (°F)": "fahrenheit"
        }
    },

    "weather-align": {
        "type": "combobox",
        "default": "left",
        "description": "Weather Alignment",
        "options": {
            "Left": "left",
            "Centre": "center",
            "Right": "right"
        }
    },

    "weather-show-condition": {
        "type": "switch",
        "default": true,
        "description": "Show Conditions"
    },

    "weather-show-icon": {
        "type": "switch",
        "default": true,
        "description": "Show Conditions Icon"
    },

    "weather-show-sun": {
        "type": "switch",
        "default": false,
        "description": "Show Sunrise & Sunset"
    },

    "weather-sun-font-family": {
        "type": "fontchooser",
        "default": "Sans 14",
        "description": "Sunrise & Sunset Font",
        "dependency": "weather-show-sun"
    },

    "weather-sun-color": {
        "type": "colorchooser",
        "default": "#FFFFFF",
        "description": "Sunrise & Sunset Color",
        "dependency": "weather-show-sun"
    },

    "text-shadow-enabled": {
        "type": "switch",
        "default": false,
        "description": "Enable Text Shadow"
    },

    "text-shadow-color": {
        "type": "colorchooser",
        "default": "#000000",
        "description": "Shadow Color",
        "dependency": "text-shadow-enabled"
    },

    "text-shadow-offset": {
        "type": "scale",
        "default": 3,
        "min": 0,
        "max": 20,
        "step": 1,
        "description": "Shadow Depth",
        "dependency": "text-shadow-enabled"
    },

    "text-shadow-blur": {
        "type": "scale",
        "default": 3,
        "min": 0,
        "max": 20,
        "step": 1,
        "description": "Shadow Softness",
        "dependency": "text-shadow-enabled"
    },

    "line-spacing": {
        "type": "scale",
        "default": 5,
        "min": 0,
        "max": 50,
        "step": 1,
        "description": "Spacing Between Labels"
    },

    "font-opacity": {
        "type": "scale",
        "default": 100,
        "min": 0,
        "max": 100,
        "step": 1,
        "description": "Text Opacity ( % )"
    },

    "label-background-color": {
        "type": "colorchooser",
        "default": "#000000",
        "description": "Label Background Color"
    },

    "label-background-opacity": {
        "type": "scale",
        "default": 0,
        "min": 0,
        "max": 100,
        "step": 1,
        "description": "Label Background Opacity"
    }
}